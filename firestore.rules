rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} { allow read, write: if false; }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'email', 'createdAt']) 
        && data.keys().size() == 3
        && data.displayName is string && data.displayName.size() >= 1 && data.displayName.size() <= 100
        && data.email is string && data.email.size() <= 200;
    }

    function isValidProgress(data) {
      return data.keys().hasAll(['challengeId', 'track', 'completedAt'])
        && data.keys().size() == 3
        && isValidId(data.challengeId)
        && data.track is string && data.track.size() <= 50;
    }

    function isValidCertificate(data) {
      return data.keys().hasAll(['rank', 'track', 'issuedAt', 'userName'])
        && data.keys().size() == 4
        && data.rank is string
        && data.track is string
        && data.userName is string && data.userName.size() <= 100;
    }

    // Rules Mapping
    match /users/{uid} {
      allow get: if isOwner(uid);
      allow create: if isOwner(uid) 
        && isValidUser(incoming()) 
        && incoming().email == request.auth.token.email
        && incoming().createdAt == request.time;
      
      allow update: if isOwner(uid) 
        && isValidUser(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName'])
        && incoming().email == existing().email
        && incoming().createdAt == existing().createdAt;

      match /challenges/{challengeId} {
        allow list, get: if isOwner(uid);
        allow create: if isOwner(uid) 
          && isValidProgress(incoming()) 
          && challengeId == incoming().challengeId
          && incoming().completedAt == request.time;
      }

      match /certificates/{certId} {
         allow list, get: if isOwner(uid);
         allow create: if isOwner(uid) 
          && isValidCertificate(incoming())
          && incoming().issuedAt == request.time;
      }
    }
  }
}
